# MCP HTML 部署服务器配置示例

# 服务监听端口
MCP_PORT=3000

# 服务监听地址
MCP_HOST=0.0.0.0

# 静态站点公网访问前缀，必须与 Nginx 的 /sites/ 前缀一致
MCP_BASE_URL=http://localhost/sites

# 静态站点在服务器磁盘上的根目录
# MCP_SITES_DIR=/var/www/mcp-sites

# 元数据和默认站点目录所在目录
# MCP_DATA_DIR=./data

# 最大上传体积，默认 50MB
# MCP_MAX_UPLOAD_BYTES=52428800

# 允许上传的静态文件后缀
# MCP_ALLOWED_EXTENSIONS=.html,.css,.js,.json,.png,.jpg,.jpeg,.gif,.svg,.ico,.webp

# --- 鉴权与站点存活时间配置 ---

# MCP 访问密钥。建议生产环境必填。客户端需使用 Authorization: Bearer <key> 或 x-api-key 连接。
# MCP_API_KEY=your-secure-api-key-here

# 用户未指定 ttl 时的默认站点存活时间。支持 3600、30m、12h、7d；不设置表示永久。
# MCP_DEFAULT_TTL=2h

# 允许用户设置的最大站点存活时间。避免用户误创建长期站点；不设置表示不限制。
# MCP_MAX_TTL=30d

# 过期站点清理检测间隔，单位毫秒，默认 60000。
# MCP_CLEANUP_INTERVAL=60000
